TOOL_DATABASE_PATH="./.data/tool.sqlite"
TOOL_YJS_DATABASE_PATH="./.data/collaboration.sqlite"
TOOL_ALLOWED_ORIGINS="http://localhost:3000"
TOOL_PAGE_SESSION_SECRET="replace-with-a-long-random-secret"
TOOL_ASSET_DIR="./.data/assets"

# No-auth MCP endpoint. Keep disabled unless you intend to expose /api/mcp.
TOOL_MCP_ENABLED="false"
TOOL_MCP_RATE_LIMIT_MAX="60"
TOOL_MCP_RATE_LIMIT_WINDOW_MS="60000"

# GLM / Z.AI OpenAI-compatible chat completions.
# Set GLM_API_KEY or ZAI_API_KEY in your local/hosted secret store.
GLM_API_KEY=""
GLM_BASE_URL="https://api.z.ai/api/paas/v4"
GLM_MODEL="glm-5.2"
GLM_TIMEOUT_MS="20000"
